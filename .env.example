# Databricks Configuration
# Get these from your Databricks workspace
DATABRICKS_WORKSPACE_URL=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_personal_access_token_here

# Atlan Instance URL (OAuth tokens come from frontend via @atlanhq/atlan-auth SDK)
ATLAN_INSTANCE_URL=https://partner-sandbox.atlan.com

# Optional: Port for local development
PORT=5001

# For production on Render, set these as environment variables in the dashboard
